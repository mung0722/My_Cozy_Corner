# Supabase 설정 (Supabase 대시보드에서 확인)

# Supabase 프로젝트의 URL
# Supabase 대시보드에서 복사
NEXT_PUBLIC_SUPABASE_URL=

# Supabase 프로젝트의 익명 키
# Supabase 대시보드 > Settings > API > anon public에서 복사
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase 프로젝트의 서비스 키(**secret**)
# Supabase 대시보드 > Settings > API > service_role에서 복사
SUPABASE_SERVICE_ROLE_KEY=